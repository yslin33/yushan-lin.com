---
import type { HTMLAttributes } from "astro/types";

type Props = Omit<HTMLAttributes<"img">, "src" | "alt" | "draggable"> & {
  src: string;
  alt: string;
};

const imageAttributes = Astro.props;

// Astro-optimized artwork may be emitted under /_astro/. It must still use this
// component, and may require host-level image response headers on a future host.
---

<img
  {...imageAttributes}
  data-protected-artwork
  draggable="false"
/>
