---
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <a class="site-name" href="/">Yu-Shan Lin</a>

  <nav aria-label="Primary navigation">
    <a
      href="/about"
      class:list={{ active: currentPath === "/about" }}
    >
      About
    </a>

    <a
      href="/notes"
      class:list={{ active: currentPath === "/notes" }}
    >
      Notes
    </a>
  </nav>
</header>

<style>
  .site-header {
    position: absolute;
    top: 30px;
    left: 30px;
    right: 30px;
    z-index: 10;

    display: flex;
    align-items: flex-start;
    justify-content: space-between;

    color: #2c2c2c;
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 14px;
    font-weight: 400;
  }

  .site-name,
  nav a {
    color: inherit;
    text-decoration: none;
  }

  .site-name {
    font-weight: 500;
    letter-spacing: 0.015em;
  }

  nav {
    display: flex;
    gap: 20px;
  }

  nav a {
    transition: color 150ms ease;
  }

  nav a:hover,
  nav a:focus-visible {
    color: #111111;
  }

  @media (max-width: 720px) {
    .site-header {
      top: 22px;
      left: 22px;
      right: 22px;
    }

    nav {
      gap: 12px;
    }
  }
</style>