---
const normalizePath = (path: string) => {
  if (path === "/") return "/";
  return path.replace(/\/+$/, "");
};

const currentPath = normalizePath(Astro.url.pathname);

const isHome = currentPath === "/";
const isAbout = currentPath === "/about";
const isNotes = currentPath === "/notes";
---

<header class="ys-header">
  <nav class="ys-header__inner" aria-label="Primary navigation">
    <a
      href="/"
      class="ys-header__link ys-header__name"
      aria-current={isHome ? "page" : undefined}
    >
      Yu-Shan Lin
    </a>

    <div class="ys-header__pages">
      <a
        href="/about"
        class="ys-header__link"
        aria-current={isAbout ? "page" : undefined}
      >
        About
      </a>

      <a
        href="/notes"
        class="ys-header__link"
        aria-current={isNotes ? "page" : undefined}
      >
        Notes
      </a>
    </div>
  </nav>
</header>

<style is:global>
  .ys-header {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 10;
    box-sizing: border-box;
    width: 100%;
    padding: 30px;
  }

  .ys-header__inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    width: 100%;
  }

  .ys-header__pages {
    display: flex;
    align-items: baseline;
    gap: 24px;
  }

  .ys-header__link {
    position: relative;
    display: inline-block;
    color: #555555;
    font-family:
      Arial,
      "Helvetica Neue",
      Helvetica,
      sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.25;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .ys-header__name {
    font-size: 14px;
  }

  .ys-header__pages .ys-header__link {
    font-size: 11.5px;
  }

  .ys-header__link::after {
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    content: "";
    opacity: 0;
    transform: scaleY(0.5);
  }

  .ys-header__link[aria-current="page"] {
    color: #222222;
  }

  .ys-header__link[aria-current="page"]::after {
    opacity: 0.25;
  }

  .ys-header__link:hover {
    color: #222222;
  }

  .ys-header__link:focus-visible {
    outline: 1px solid currentColor;
    outline-offset: 5px;
  }

  @media (max-width: 720px) {
    .ys-header {
      padding: 22px;
    }

    .ys-header__pages {
      gap: 18px;
    }
  }
</style>
