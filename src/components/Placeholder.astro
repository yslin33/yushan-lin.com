---
interface Props {
  message?: string;
}

const { message = "In progress." } = Astro.props;
---

<div class="status" role="status" aria-live="polite">
  <span class="loader" aria-hidden="true"></span>
  <p>{message}</p>
</div>

<style>
  .status {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-muted);
    font-size: var(--text-sm);
    font-weight: 400;
  }

  .status p {
    margin: 0;
    line-height: 1;
  }

  .loader {
    width: 13px;
    height: 13px;
    flex: 0 0 auto;
    border: 1.5px solid #b8b8b8;
    border-top-color: #303030;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .loader {
      animation: none;
    }
  }
</style>