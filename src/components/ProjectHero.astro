---
import ProjectFigure from "./ProjectFigure.astro";

interface ImageMetadata {
  src: string;
}

interface Props {
  image?: ImageMetadata;
  alt: string;
  caption: string;
  heroLayout?: "full" | "portrait";
}

const {
  image,
  alt,
  caption,
  heroLayout = "full",
} = Astro.props;
---

<div class:list={["project-hero", `project-hero--${heroLayout}`]}>
  <div class="project-hero__opening">
    <slot />
  </div>

  <ProjectFigure
    src={image?.src}
    alt={alt}
    caption={caption}
    loading="eager"
    variant={heroLayout}
  />
</div>

<style>
  .project-hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

</style>
