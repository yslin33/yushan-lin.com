---
interface MetadataItem {
  label: string;
  value?: string;
}

interface Props {
  items: MetadataItem[];
}

const items = Astro.props.items.filter((item) => item.value?.trim());
---

{
  items.length > 0 && (
    <dl class="project-metadata type-nav">
      {items.map((item) => (
        <div class="project-metadata__item">
          <dt>{item.label}</dt>
          <dd>{item.value}</dd>
        </div>
      ))}
    </dl>
  )
}

<style>
  .project-metadata {
    display: grid;
    gap: var(--space-xs);
    margin: 0;
  }

  .project-metadata__item {
    display: grid;
    grid-template-columns: minmax(88px, 0.35fr) minmax(0, 1fr);
    gap: var(--space-sm);
  }

  dt,
  dd {
    margin: 0;
  }

  dt {
    color: var(--color-faint);
  }

  dd {
    color: var(--color-muted);
    white-space: pre-line;
  }
</style>
