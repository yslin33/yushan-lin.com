---
import ArtworkImage from "./ArtworkImage.astro";

export interface GalleryItem {
  image: string;
  title: string;
  location?: string;
  date?: string;
}

interface Props {
  heading: string;
  folder: string;
  items: GalleryItem[];
  itemLabel?: string;
  showMobileCaptions?: boolean;
  sectionClass?: string;
}

const {
  heading,
  folder,
  items,
  itemLabel = "image",
  showMobileCaptions = true,
  sectionClass,
} = Astro.props;
const initialItems = items.slice(0, Math.min(3, items.length));
---

<section
  class:list={["thumbnail-gallery", sectionClass]}
  data-gallery-root
  data-gallery-folder={folder}
  data-gallery-items={JSON.stringify(items)}
>
  <h2 class="type-nav">{heading}</h2>

  <div class="visual-note-row archive-image-row">
    {
      initialItems.map((item, index) => (
        <button
          class="visual-note visual-note-trigger"
          type="button"
          aria-label={`View ${item.title || itemLabel}`}
          data-lightbox-folder={folder}
          data-lightbox-index={index}
          data-gallery-slot={index}
        >
          <span class="visual-note-frame notes-image-wrapper">
            <ArtworkImage
              class="notes-image"
              src={item.image}
              alt={[item.title, item.location].filter(Boolean).join(" — ") || itemLabel}
              loading="lazy"
            />
          </span>
          {showMobileCaptions && (
            <span class="visual-note-mobile-caption type-nav">
              <span data-gallery-caption-title>{item.title}</span>
              <span data-gallery-caption-meta>
                {[item.location, item.date?.replace("-", ".")].filter(Boolean).join(" · ")}
              </span>
            </span>
          )}
        </button>
      ))
    }
  </div>

  <div class="visual-note-nav type-nav" aria-label={`${heading} navigation`}>
    <button
      class="gallery-nav-control gallery-nav__control"
      type="button"
      aria-label={`Previous ${itemLabel}`}
      data-gallery-direction="-1"
    >
      <span aria-hidden="true">‹</span>
    </button>
    <button
      class="gallery-nav-control gallery-nav__control"
      type="button"
      aria-label={`Next ${itemLabel}`}
      data-gallery-direction="1"
    >
      <span aria-hidden="true">›</span>
    </button>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-gallery-root]").forEach((gallery) => {
    if (gallery.dataset.galleryInitialized === "true") return;
    gallery.dataset.galleryInitialized = "true";

    type GalleryItem = {
      image: string;
      title: string;
      location?: string;
      date?: string;
    };

    const items = JSON.parse(gallery.dataset.galleryItems || "[]") as GalleryItem[];
    const slots = Array.from(gallery.querySelectorAll<HTMLButtonElement>("[data-gallery-slot]"));
    const controls = gallery.querySelectorAll<HTMLButtonElement>(".gallery-nav__control");
    const mobileGalleryMedia = window.matchMedia("(max-width: 767px)");
    const visibleCount = slots.length;
    let currentStartIndex = 0;

    const updateImageOrientation = (image: HTMLImageElement) => {
      const frame = image.closest<HTMLElement>(".notes-image-wrapper");
      if (!frame || image.naturalWidth === 0 || image.naturalHeight === 0) return;

      frame.classList.remove("is-portrait", "is-landscape");
      frame.classList.add(
        image.naturalHeight > image.naturalWidth ? "is-portrait" : "is-landscape",
      );
    };

    slots.forEach((slot) => {
      const image = slot.querySelector<HTMLImageElement>("img");
      if (!image) return;
      image.addEventListener("load", () => updateImageOrientation(image));
      if (image.complete) updateImageOrientation(image);
    });

    const updateVisibleItems = () => {
      if (items.length === 0) return;

      const visibleItems = Array.from(
        { length: visibleCount },
        (_, offset) => items[(currentStartIndex + offset) % items.length],
      );
      gallery.dataset.galleryStartIndex = String(currentStartIndex);

      slots.forEach((slot, slotIndex) => {
        const item = visibleItems[slotIndex];
        if (!item) return;

        const itemIndex = (currentStartIndex + slotIndex) % items.length;
        slot.dataset.lightboxIndex = String(itemIndex);
        slot.setAttribute("aria-label", `View ${item.title || "image"}`);

        const image = slot.querySelector<HTMLImageElement>("img");
        if (image) {
          image.closest(".notes-image-wrapper")?.classList.remove("is-portrait", "is-landscape");
          image.src = item.image;
          image.alt = [item.title, item.location].filter(Boolean).join(" — ") || "Project image";
          if (image.complete) updateImageOrientation(image);
        }

        const captionTitle = slot.querySelector<HTMLElement>("[data-gallery-caption-title]");
        const captionMeta = slot.querySelector<HTMLElement>("[data-gallery-caption-meta]");
        if (captionTitle) captionTitle.textContent = item.title;
        if (captionMeta) {
          const displayDate = item.date && /^\d{4}-\d{2}$/.test(item.date)
            ? item.date.replace("-", ".")
            : item.date || "";
          captionMeta.textContent = [item.location, displayDate].filter(Boolean).join(" · ");
        }
      });
    };

    const updateThumbnailInteraction = () => {
      slots.forEach((slot) => {
        slot.disabled = mobileGalleryMedia.matches;
      });
    };

    controls.forEach((control) => {
      control.addEventListener("click", (event) => {
        event.stopPropagation();
        if (items.length === 0) return;
        const direction = Number(control.dataset.galleryDirection || 0);
        currentStartIndex = (currentStartIndex + direction + items.length) % items.length;
        updateVisibleItems();
      });
    });

    updateVisibleItems();
    updateThumbnailInteraction();
    mobileGalleryMedia.addEventListener("change", updateThumbnailInteraction);
  });
</script>

<style>
  h2 {
    margin: 0 0 16px;
    color: #2c2c2c;
  }

  .visual-note-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .visual-note,
  .visual-note-frame {
    display: block;
  }

  .visual-note-trigger {
    width: 100%;
    min-width: 0;
    margin: 0;
    padding: 0;
    border: 0;
    border-radius: 0;
    appearance: none;
    background: none;
    box-shadow: none;
    color: inherit;
    font: inherit;
    outline: none;
    cursor: pointer;
  }

  .visual-note-trigger:focus-visible {
    opacity: 0.72;
  }

  .visual-note-nav {
    display: flex;
    justify-content: center;
    width: 100%;
    gap: 28px;
    margin-top: 12px;
    color: var(--color-faint);
  }

  .visual-note-nav .gallery-nav-control {
    margin: 0;
    padding: 0;
    border: 0;
    border-radius: 0;
    appearance: none;
    -webkit-appearance: none;
    min-width: 0;
    min-height: 0;
    background: transparent;
    box-shadow: none;
    color: inherit;
    font: inherit;
    font-size: 13px;
    line-height: 1;
    outline: none;
    opacity: 0.65;
    cursor: pointer;
  }

  .visual-note-nav .gallery-nav-control:hover,
  .visual-note-nav .gallery-nav-control:active,
  .visual-note-nav .gallery-nav-control:focus-visible {
    border: 0;
    background: transparent;
    box-shadow: none;
    outline: none;
    opacity: 0.85;
  }

  .visual-note-nav .gallery-nav-control:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .visual-note-frame {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .archive-image-row .visual-note {
    min-width: 0;
  }

  .archive-image-row img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    object-fit: contain;
  }

  .visual-note-mobile-caption {
    display: none;
  }

  @media (max-width: 767px) {
    h2 {
      margin-bottom: var(--space-sm);
    }

    .visual-note-trigger:disabled {
      cursor: default;
    }

    .visual-note-frame {
      width: 100%;
      max-width: 100%;
      margin-inline: auto;
      aspect-ratio: auto;
      overflow: visible;
    }

    .notes-image {
      display: block;
      height: auto;
    }

    .notes-image-wrapper.is-landscape .notes-image {
      width: 100%;
      max-width: 100%;
    }

    .notes-image-wrapper.is-portrait {
      display: flex;
      justify-content: center;
    }

    .notes-image-wrapper.is-portrait .notes-image {
      width: auto;
      max-width: 60%;
      height: auto;
    }

    .visual-note-nav {
      margin-top: var(--space-sm);
    }

    .visual-note-mobile-caption {
      display: block;
      margin-top: var(--space-xs);
      color: var(--color-muted);
      text-align: right;
    }

    .notes-section .visual-note-mobile-caption {
      text-align: left;
    }

    .notes-section .notes-image-wrapper.is-portrait + .visual-note-mobile-caption {
      width: 60%;
      margin-inline: auto;
    }

    .visual-note-mobile-caption span {
      display: block;
    }
  }

  @media (max-width: 639px) {
    .visual-note-row {
      grid-template-columns: minmax(0, 1fr);
    }

    .visual-note-row .visual-note:nth-child(n + 2) {
      display: none;
    }
  }
</style>
