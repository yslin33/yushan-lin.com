---
import LanguageSwitch from "./LanguageSwitch.astro";
import Placeholder from "./Placeholder.astro";
import PublicationPageShell from "./PublicationPageShell.astro";

interface Props {
  title: string;
  slug: string;
  date: string;
  language?: "en" | "zh";
}

const { title, slug, date, language = "en" } = Astro.props;
const englishHref = `/writing/${slug}`;
const chineseHref = `/writing/${slug}-zh`;
---

<PublicationPageShell backHref="/notes" backLabel="Notes">
  <main class="writing-page mobile-content-start" lang={language === "zh" ? "zh-Hant" : "en"}>
    <article class="content-column">
      <div class="text-column writing-page__content">
      <div class="writing-page__meta-row">
        <time class="type-nav editorial-meta" datetime={date.replace(".", "-")}>{date}</time>

        <LanguageSwitch
          currentLanguage={language}
          englishHref={englishHref}
          chineseHref={chineseHref}
        />
      </div>

      <h1 class="type-writing-title">{title}</h1>

      <hr />

        <div class="writing-page__placeholder">
          <Placeholder message="In progress." />
        </div>
      </div>
    </article>
  </main>
</PublicationPageShell>

<style>
  .writing-page {
    display: flex;
    flex: 1 0 auto;
    padding: 150px 0 0;
  }

  .writing-page > article {
    display: flex;
  }

  .writing-page__content {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--space-sm);
    color: #4f4f4f;
  }

  h1,
  p,
  time {
    margin: 0;
  }

  h1 {
    color: #2c2c2c;
  }

  .writing-page__meta-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-md);
  }

  hr {
    width: 100%;
    margin: 0;
    border: 0;
    border-top: 1px solid #e5e5e5;
  }

  .writing-page__placeholder {
    display: flex;
    flex: 1;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }

</style>
