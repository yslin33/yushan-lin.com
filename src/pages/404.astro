---
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicationPageShell from "../components/PublicationPageShell.astro";
---

<BaseLayout
  title="Page Not Found | Yu-Shan Lin"
  description="This page cannot be found."
>
  <PublicationPageShell backHref="/" backLabel="Home" centeredMain>
    <main class="not-found-page">
      <div class="content-column">
        <div class="text-column not-found-content">
          <h1 class="type-writing-title">404</h1>

          <div class="not-found-message type-body">
            <p>This page cannot be found.</p>
            <p>
              It may have been moved, removed,<br />
              or perhaps it has not been published yet.
            </p>
          </div>
        </div>
      </div>
    </main>
  </PublicationPageShell>
</BaseLayout>

<style>
  .not-found-page {
    display: flex;
    flex: 1;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: var(--page-padding);
  }

  .text-column.not-found-content {
    width: 100%;
    max-width: 450px;
    margin-inline: auto;
    text-align: center;
  }

  .not-found-content h1,
  .not-found-content p {
    text-align: center;
  }

  h1,
  p {
    margin: 0;
  }

  .not-found-message {
    margin-top: var(--space-sm);
  }

  .not-found-message p + p {
    margin-top: var(--space-md);
  }

  .not-found-message p:first-child {
    color: var(--color-text);
  }

</style>
