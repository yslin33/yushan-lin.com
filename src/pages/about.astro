---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About | Yu-Shan Lin"
  description="About Yu-Shan Lin, an architectural designer based between Taipei and Philadelphia."
>
  <main class="about-page mobile-content-start">
    <div class="content-column">
      <div class="text-column about-column type-body">
        <section class="intro">
          <p>
            Yu-Shan Lin is an architectural designer based between Taipei and
            Philadelphia.
          </p>

          <p>
            Her work explores memory, atmosphere, and the experience of
            architecture through drawing, making, photography, and writing.
          </p>
        </section>

        <section>
          <h2 class="type-nav">Education</h2>

          <div class="entry">
            <p>Master of Architecture '28</p>
            <p>University of Pennsylvania</p>
          </div>

          <div class="entry">
            <p>B.S. in Architecture '24</p>
            <p>National Taipei University of Technology</p>
          </div>
        </section>

        <section>
          <h2 class="type-nav">Experience</h2>

          <div class="entry">
            <p>Fab Lab Technician</p>
            <p>University of Pennsylvania</p>
          </div>

          <div class="entry">
            <p>Architectural Designer</p>
            <p>Fieldscape Architects + Planners</p>
          </div>

          <div class="entry">
            <p>Interior Designer</p>
            <p>Cozy Nest Interior Design</p>
          </div>
        </section>

        <section>
          <h2 class="type-nav">Elsewhere</h2>

          <div class="links">
            <a href="mailto:yslin33@design.upenn.edu">
              Email
            </a>

            <a
              href="https://www.instagram.com/yushan.lin_archives"
              target="_blank"
              rel="noopener noreferrer"
            >
              Instagram
            </a>

            <a
              href="https://www.linkedin.com/in/yslin33/"
              target="_blank"
              rel="noopener noreferrer"
            >
              LinkedIn
            </a>
          </div>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .about-page {
    min-height: 100vh;
    padding: 150px 0 100px;
  }

  .about-column {
    color: #4f4f4f;
  }

  h2,
  p {
    margin: 0;
  }

  section + section {
    margin-top: 64px;
  }

  h2 {
    margin-bottom: 16px;
    color: #2c2c2c;
  }

  .intro p,
  .entry p,
  .links a {
    font-size: inherit;
    line-height: inherit;
  }

  .intro p + p {
    margin-top: 18px;
  }

  .entry + .entry {
    margin-top: var(--space-entry);
  }

  .entry p:first-child {
    color: #2c2c2c;
  }

  .entry p:last-child {
    color: #666666;
  }

  .links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  .links a {
    color: inherit;
    text-decoration: none;
    transition:
      color 150ms ease,
      transform 150ms ease;
  }

  .links a:hover,
  .links a:focus-visible {
    color: #111111;
    transform: translateX(2px);
  }

  @media (max-width: 720px) {
    .about-page {
      padding-bottom: 80px;
    }

    section + section {
      margin-top: 52px;
    }

  }
</style>
