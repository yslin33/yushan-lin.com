---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About | Yu-Shan Lin"
  description="About Yu-Shan Lin, an architectural designer based between Taipei and Philadelphia."
>
  <main class="about-page">
    <div class="content-column about-column">
      <section class="intro">
        <p>
          Yu-Shan Lin is an architectural designer based between Taipei and Philadelphia.
        </p>

        <p>
          Her work explores memory, atmosphere, and the experience of
          architecture through drawing, making, photography, and writing.
        </p>
      </section>

      <section>
        <h2>Education</h2>

        <div class="entry">
          <p>Master of Architecture '28</p>
          <p>University of Pennsylvania</p>
        </div>

        <div class="entry">
          <p>B.S. in Architecture '24</p>
          <p>National Taipei University of Technology</p>
        </div>
      </section>

      <section>
        <h2>Experience</h2>

        <div class="entry">
          <p>Fab Lab Technician</p>
          <p>University of Pennsylvania</p>
        </div>

        <div class="entry">
          <p>Architectural Designer</p>
          <p>Fieldscape Architects + Planners</p>
        </div>

        <div class="entry">
          <p>Interior Designer</p>
          <p>Cozy Nest Interior Design</p>
        </div>
      </section>

      <section>
        <h2>Elsewhere</h2>

        <div class="links">
          <a href="mailto:yslin33@design.upenn.edu">
            Email
          </a>

          <a
            href="https://www.instagram.com/yushan.lin_archives"
            target="_blank"
            rel="noopener noreferrer"
          >
            Instagram
          </a>

          <a
            href="https://www.linkedin.com/in/yslin33/"
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .about-page {
    min-height: 100vh;
    padding: 150px 0px 100px;
  }

  section + section {
    margin-top: 64px;
  }

  h2,
  p {
    margin: 0;
  }

  h2 {
    margin-bottom: 20px;
    color: #2c2c2c;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .intro p {
    max-width: 450px;
    line-height: 1.45;
  }

  .intro p + p {
    margin-top: 16px;
  }

  .entry + .entry {
    margin-top: 20px;
  }

  .entry p {
    line-height: 1.45;
  }

  .entry p:first-child {
    color: #2c2c2c;
  }

  .links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  .links a {
    color: inherit;
    text-decoration: none;
    transition:
      color 150ms ease,
      transform 150ms ease;
  }

  .links a:hover,
  .links a:focus-visible {
    color: #111111;
    transform: translateX(2px);
  }

  @media (max-width: 720px) {
    .about-page {
      padding: 120px 0px 80px;
    }

    section + section {
      margin-top: 52px;
    }
  }
</style>