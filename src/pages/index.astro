---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Yu-Shan Lin"
  description="Yu-Shan Lin — architectural design, observation, and writing."
>
  <main class="home-main">
    <section class="intro content-column text-column">
      <p class="description">
        Exploring how spaces are made, experienced, and remembered.
      </p>

      <ul class="project-list">
        <li>
          <a href="/projects/soft-edges-hard-grids">
            Soft Edges, Hard Grids
          </a>
        </li>

        <li>
          <a href="/projects/porous-stratification">
            Porous Stratification
          </a>
        </li>

        <li>
          <a href="/projects/visions-in-beitou">
            Visions in Beitou / Beitou in Visions: 2024 Memorial
          </a>
        </li>
      </ul>
    </section>
  </main>

  <footer class="site-footer">
    <span>Philadelphia, PA</span>

    <time
      id="philadelphia-time"
      aria-label="Current time in Philadelphia"
    >
      --:--:-- ET
    </time>
  </footer>

  <script>
    const timeElement = document.querySelector("#philadelphia-time");

    function updatePhiladelphiaTime() {
      if (!(timeElement instanceof HTMLTimeElement)) return;

      const now = new Date();

      const time = new Intl.DateTimeFormat("en-US", {
        timeZone: "America/New_York",
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: false,
      }).format(now);

      timeElement.textContent = `${time} ET`;
      timeElement.dateTime = now.toISOString();
    }

    updatePhiladelphiaTime();
    window.setInterval(updatePhiladelphiaTime, 1000);
  </script>
</BaseLayout>

<style>
  :global(body) {
    display: grid;
    grid-template-rows: 1fr auto;
    min-height: 100vh;
    padding: 30px;
  }

  .home-main {
    position: relative;
    min-height: 0;
  }

  .intro {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .description {
    max-width: 450px;
    margin: 0 0 32px;
    line-height: 1.45;
  }

  .project-list {
    margin: 0;
    padding: 0;
    list-style: none;
    white-space: nowrap;
  }

  .project-list li {
    line-height: 1.5;
  }

  .project-list a {
    display: inline-flex;
    align-items: baseline;
    transition:
      color 150ms ease,
      transform 150ms ease;
  }

  .project-list a::before {
    content: "→";
    flex: 0 0 auto;
    margin-right: 9px;
  }

  .project-list a:hover,
  .project-list a:focus-visible {
    color: #111111;
    transform: translateX(2px);
  }

  .site-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    color: #2c2c2c;
    font-size: 10.5px;
    letter-spacing: 0.01em;
  }

  #philadelphia-time {
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 900px) {
    .project-list {
      white-space: normal;
    }
  }

  @media (max-width: 720px) {
    :global(body) {
      padding: 22px;
    }

    .intro {
      position: static;
      left: auto;
      margin-top: 30vh;
      transform: none;
    }

    .description {
      max-width: 100%;
    }

    .project-list {
      white-space: normal;
    }

    .site-footer {
      margin-top: 100px;
      font-size: 10px;
    }
  }
</style>