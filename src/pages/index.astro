---
import BaseLayout from "../layouts/BaseLayout.astro";
import CopyrightFooter from "../components/CopyrightFooter.astro";
---

<BaseLayout
  title="Yu-Shan Lin"
  description="Yu-Shan Lin — architectural design, observation, and writing."
>
  <div class="home-page">
    <main class="home-main">
      <section class="intro">
        <div class="content-column">
          <div class="text-column intro-content">
            <p class="description type-body">
              Exploring how spaces are made, experienced, and remembered.
            </p>

            <ul class="project-list">
              <li>
                <a href="/projects/soft-edges-hard-grids">
                  Soft Edges, Hard Grids
                </a>
              </li>

              <li>
                <a href="/projects/porous-stratification">
                  Porous Stratification
                </a>
              </li>

              <li>
                <a href="/projects/visions-in-beitou">
                  Visions in Beitou / Beitou in Visions: 2024 Memorial
                </a>
              </li>
            </ul>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <span class="site-footer__location">Philadelphia, PA</span>

      <CopyrightFooter inRow />

      <time
        id="philadelphia-time"
        aria-label="Current time in Philadelphia"
      >
        --:--:-- ET
      </time>
    </footer>
  </div>

  <script>
    const timeElement = document.querySelector("#philadelphia-time");

    function updatePhiladelphiaTime() {
      if (!(timeElement instanceof HTMLTimeElement)) return;

      const now = new Date();

      const time = new Intl.DateTimeFormat("en-US", {
        timeZone: "America/New_York",
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: false,
      }).format(now);

      timeElement.textContent = `${time} ET`;
      timeElement.dateTime = now.toISOString();
    }

    updatePhiladelphiaTime();
    window.setInterval(updatePhiladelphiaTime, 1000);
  </script>
</BaseLayout>

<style>
  .home-page {
    display: grid;
    grid-template-rows: 1fr auto;
    min-height: 100vh;
  }

  .home-main {
    position: relative;
    min-height: 0;
  }

  .intro {
    position: absolute;
    top: 50%;
    width: 100%;
    transform: translateY(-50%);
  }

  .description {
    margin: 0 0 var(--space-lg);
  }

  .project-list {
    margin: 0;
    padding: 0;
    list-style: none;
    white-space: nowrap;
  }

  .project-list li {
    line-height: 1.5;
  }

  .project-list li + li {
    margin-top: 10px;
  }

  .project-list a {
    display: inline-flex;
    align-items: baseline;
    transition:
      color 150ms ease,
      transform 150ms ease;
  }

  .project-list a::before {
    content: "→";
    flex: 0 0 auto;
    margin-right: 9px;
  }

  .project-list a:hover,
  .project-list a:focus-visible {
    color: #111111;
    transform: translateX(2px);
  }

  .site-footer {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: baseline;
    width: calc(100% - (var(--page-padding) * 2));
    margin-inline: auto;
    padding-bottom: var(--page-padding);
    color: var(--color-muted);
    font-family:
      Calibri,
      "Helvetica Neue",
      Arial,
      sans-serif;
    font-size: 11.5px;
    font-weight: 400;
    line-height: var(--line-height-normal);
    letter-spacing: 0.015em;
  }

  .site-footer__location {
    justify-self: start;
  }

  #philadelphia-time {
    justify-self: end;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 900px) {
    .project-list {
      white-space: normal;
    }
  }

  @media (max-width: 720px) {
    .home-main {
      display: grid;
      align-items: center;
    }

    .intro {
      position: static;
      width: auto;
      transform: none;
    }

    .site-footer {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      justify-content: space-between;
      margin-top: 72px;
    }

    .site-footer__location {
      order: 1;
    }

    #philadelphia-time {
      order: 2;
    }
  }
</style>
