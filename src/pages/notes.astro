---
import BaseLayout from "../layouts/BaseLayout.astro";
import NotesLightbox from "../components/NotesLightbox.astro";
import ThumbnailGallery from "../components/ThumbnailGallery.astro";
import { sortEntriesByDate } from "../utils/sortEntriesByDate";

const photographySource = [
  {
    image: "/images/notes/photography/2018-04-reichstag-dome.jpg",
    title: "Reichstag Dome",
    location: "Berlin, Germany",
    date: "2018-04",
  },
  {
    image: "/images/notes/photography/2018-04-jewish-museum-berlin.jpg",
    title: "Jewish Museum Berlin",
    location: "Berlin, Germany",
    date: "2018-04",
  },
  {
    image: "/images/notes/photography/2018-04-schloss-sanssouci.jpg",
    title: "Schloss Sanssouci",
    location: "Potsdam, Germany",
    date: "2018-04",
  },
  {
    image: "/images/notes/photography/2018-04-berliner-dom.jpg",
    title: "Berliner Dom",
    location: "Berlin, Germany",
    date: "2018-04",
  },
  {
    image: "/images/notes/photography/2018-07-sule-pagoda.jpg",
    title: "Sule Pagoda",
    location: "Yangon, Myanmar",
    date: "2018-07",
  },
];

const sketchSource = [
  {
    title: "DOZO Izakaya",
    location: "Taipei, Taiwan",
    date: "2017-08",
    image: "/images/notes/sketches/2017-08-dozo-izakaya.jpg",
  },
  {
    title: "Rooftops beneath 20F",
    location: "Taipei, Taiwan",
    date: "2017-08",
    image: "/images/notes/sketches/2017-08-rooftops-beneath-20f.jpg",
  },
  {
    title: "Nanliao Fish Market",
    location: "Hsinchu, Taiwan",
    date: "2017-08",
    image: "/images/notes/sketches/2017-08-nanliao-fish-market.jpg",
  },
  {
    title: "Nanliao Harbor",
    location: "Hsinchu, Taiwan",
    date: "2017-08",
    image: "/images/notes/sketches/2017-08-nanliao-harbor.jpg",
  },
  {
    title: "Taipei",
    location: "Taipei, Taiwan",
    date: "2017-10",
    image: "/images/notes/sketches/2017-10-taipei.jpg",
  },
  {
    title: "Kiyomizu-dera",
    location: "Kyoto, Japan",
    date: "2023-07",
    image: "/images/notes/sketches/2023-07-kiyomizu-dera.jpg",
  },
  {
    title: "Yasaka Shrine",
    location: "Kyoto, Japan",
    date: "2023-07",
    image: "/images/notes/sketches/2023-07-yasaka-shrine.jpg",
  },
  {
    title: "Arashiyama",
    location: "Kyoto, Japan",
    date: "2023-07",
    image: "/images/notes/sketches/2023-07-arashiyama.jpg",
  },
  {
    title: "Tsutenkaku",
    location: "Osaka, Japan",
    date: "2023-07",
    image: "/images/notes/sketches/2023-07-tsutenkaku.jpg",
  },
];

const sortArchiveByDate = <T extends { date: string }>(items: T[]) =>
  items
  .map((item, originalIndex) => ({ item, originalIndex }))
  .sort(
    (a, b) =>
      a.item.date.localeCompare(b.item.date) || a.originalIndex - b.originalIndex,
  )
  .map(({ item }) => item);

const photographyNotes = sortArchiveByDate(photographySource);
const sketchNotes = sortArchiveByDate(sketchSource);

interface WritingNote {
  title: string;
  href: string;
  date: string;
}

const writingSource: WritingNote[] = [
  {
    title: "Kasiboan",
    href: "/writing/kasiboan",
    date: "2024-07",
  },
  {
    title: "The Memory of the City, The Memory of Beitou",
    href: "/writing/the-memory-of-the-city-the-memory-of-beitou",
    date: "2023-12",
  },
  {
    title: "Memory and Memorial",
    href: "/writing/memory-and-memorial",
    date: "2024-11",
  },
  {
    title: "Fractured Cities",
    href: "/writing/fractured-cities",
    date: "2024-12",
  },
];

// Writing: oldest to newest; undated or in-progress entries appear last.
const writingNotes = sortEntriesByDate(writingSource, "ascending");
---

<BaseLayout
  title="Notes | Yu-Shan Lin"
  description="Notes by Yu-Shan Lin on architecture, observation, cities, and memory."
>
  <main class="notes-page mobile-content-start">
    <div class="content-column">
      <div class="text-column notes-sections">
        <ThumbnailGallery
          heading="Photography"
          folder="photography"
          items={photographyNotes}
          itemLabel="photograph"
          sectionClass="notes-section"
        />

        <ThumbnailGallery
          heading="Sketches"
          folder="sketches"
          items={sketchNotes}
          itemLabel="sketch"
          sectionClass="notes-section"
        />

        <section class="notes-section">
          <h2 class="type-nav">Writing</h2>

          <ul class="writing-list type-body">
            {
              writingNotes.map((note) => (
                <li>
                  <a href={note.href}>{note.title}</a>
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </div>
  </main>

  <NotesLightbox
    galleries={{ photography: photographyNotes, sketches: sketchNotes }}
  />
</BaseLayout>

<style>
  .notes-page {
    min-height: 100vh;
    padding: 150px 0 100px;
  }

  .notes-sections {
    display: flex;
    flex-direction: column;
    gap: var(--section-gap);
  }

  section > h2 {
    margin: 0 0 16px;
    color: #2c2c2c;
  }

  .writing-list {
    margin: 0;
    padding: 0;
    list-style: none;
    white-space: nowrap;
  }

  .writing-list li {
    line-height: 1.5;
  }

  .writing-list li + li {
    margin-top: 10px;
  }

  .writing-list a {
    display: inline-flex;
    align-items: baseline;
  }

  .writing-list a::before {
    content: "→";
    flex: 0 0 auto;
    margin-right: 9px;
  }

  @media (max-width: 720px) {
    .notes-page {
      padding-bottom: 80px;
    }

    .writing-list {
      white-space: normal;
    }
  }

</style>
