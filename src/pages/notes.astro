---
import BaseLayout from "../layouts/BaseLayout.astro";
import Placeholder from "../components/Placeholder.astro";
---

<BaseLayout
  title="Notes | Yu-Shan Lin"
  description="Notes by Yu-Shan Lin on architecture, observation, cities, and memory."
>
  <main class="notes-page">
    <Placeholder />
  </main>
</BaseLayout>

<style>
  .notes-page {
    position: fixed;
    inset: 0;
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    padding: var(--page-padding);
    pointer-events: none;
  }

  .notes-page :global(*) {
    pointer-events: auto;
  }
</style>