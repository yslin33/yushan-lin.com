---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Placeholder from "../../components/Placeholder.astro";
import ProjectPage from "../../components/ProjectPage.astro";
---

<BaseLayout
  title="滲透層疊 | Yu-Shan Lin"
  description="Yu-Shan Lin 的建築設計專案〈滲透層疊〉。"
  additionalFontStylesheet="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600&display=swap"
  language="zh-Hant"
>
  <ProjectPage
    title="滲透層疊"
    date="2025 秋"
    currentLanguage="zh"
    englishHref="/projects/porous-stratification"
    chineseHref="/projects/porous-stratification-zh"
    placeholder
  >
    <div class="project-placeholder">
      <Placeholder message="In progress." />
    </div>
  </ProjectPage>
</BaseLayout>

<style>
  .project-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 240px;
  }
</style>
