---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Placeholder from "../../components/Placeholder.astro";
import ProjectPage from "../../components/ProjectPage.astro";
---

<BaseLayout
  title="軟邊界與硬格網 | Yu-Shan Lin"
  description="Yu-Shan Lin 的建築設計專案〈軟邊界與硬格網〉。"
  additionalFontStylesheet="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600&display=swap"
  language="zh-Hant"
>
  <ProjectPage
    title="軟邊界與硬格網"
    date="2026 春"
    dateTime="2026"
    currentLanguage="zh"
    englishHref="/projects/soft-edges-hard-grids"
    chineseHref="/projects/soft-edges-hard-grids-zh"
    placeholder
  >
    <div class="project-placeholder">
      <Placeholder message="In progress." />
    </div>
  </ProjectPage>
</BaseLayout>

<style>
  .project-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 240px;
  }
</style>
