---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Placeholder from "../../components/Placeholder.astro";
import ProjectPage from "../../components/ProjectPage.astro";
---

<BaseLayout
  title="夢北投：貳零貳肆紀念場 | Yu-Shan Lin"
  description="Yu-Shan Lin 的建築設計專案〈夢北投：貳零貳肆紀念場〉。"
  additionalFontStylesheet="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600&display=swap"
  language="zh-Hant"
>
  <ProjectPage
    title="夢北投：貳零貳肆紀念場"
    date="2023 秋－2024 春"
    currentLanguage="zh"
    englishHref="/projects/visions-in-beitou"
    chineseHref="/projects/visions-in-beitou-zh"
    placeholder
  >
    <div class="project-placeholder">
      <Placeholder message="In progress." />
    </div>
  </ProjectPage>
</BaseLayout>

<style>
  .project-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 240px;
  }
</style>
