---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Placeholder from "../../components/Placeholder.astro";
---

<BaseLayout
  title="Collect and Recall | Yu-Shan Lin"
  description="An essay by Yu-Shan Lin."
>
  <main class="placeholder-page">
    <Placeholder message="In progress." />
  </main>
</BaseLayout>

<style>
  .placeholder-page {
    position: fixed;
    inset: 0;
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    padding: var(--page-padding);
    pointer-events: none;
  }

  .placeholder-page :global(*) {
    pointer-events: auto;
  }
</style>
